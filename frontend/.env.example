# Vercel Blob Storage (auto-configurato se usi Vercel Blob dal dashboard)
BLOB_READ_WRITE_TOKEN=

# JWT secret per autenticazione admin
JWT_SECRET=cambia-con-una-stringa-sicura-random

# Hash bcrypt della password admin (generato con: npx bcryptjs hash "la-tua-password")
ADMIN_PASSWORD_HASH=$2y$10$0VcV1r0GRLLoDe7ie.HFtOQxDvJJVz9uLWw1cepCUXdY.PLP0ztc.

# OpenAI API key per la funzione "migliora testo"
OPENAI_API_KEY=

# Secret per il seed iniziale dei dati
SEED_SECRET=cambia-con-una-stringa-random
